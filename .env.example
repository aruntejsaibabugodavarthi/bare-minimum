# Database Connection
DATABASE_URL="postgresql://user:password@localhost:5432/bare_minimum"

# Server Configuration
PORT=8081
ALLOWED_ORIGINS="http://localhost:8081,https://yourdomain.com"

# Razorpay Keys (Get these from your Razorpay Dashboard)
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="..."

# JWT Secrets (Generate strong random strings in production)
JWT_ACCESS_SECRET="your_access_secret_here"
JWT_REFRESH_SECRET="your_refresh_secret_here"
